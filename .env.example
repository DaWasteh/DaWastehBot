# ---------------------------------------------------------------------------
# PandaBot Konfiguration
# Kopiere diese Datei zu ".env" und trage deine eigenen Werte ein.
# Die .env wird NICHT versioniert (siehe .gitignore).
# ---------------------------------------------------------------------------

# --- Twitch Application (aus https://dev.twitch.tv/console) ---
TWITCH_CLIENT_ID=hier_deine_client_id
TWITCH_CLIENT_SECRET=hier_dein_client_secret

# Numerische User-IDs (NICHT die Namen!). So findest du sie:
# https://twitchio.dev/en/latest/getting-started/faq.html#bot-id-owner-id
TWITCH_BOT_ID=123456789      # User-ID des Bot-Accounts
TWITCH_OWNER_ID=987654321    # Deine eigene User-ID (der Kanal)

# Anzeigename / zusätzlicher Spitzname, auf den der Bot hört.
# Der echte Account-Name (Login) wird automatisch als Trigger erkannt;
# hier kannst du zusätzlich einen Spitznamen angeben (z. B. "PandaBot").
# Wird außerdem in Prompts/Logs verwendet.
TWITCH_CHANNEL=hier_dein_kanal_name
TWITCH_BOT_NAME=hier_dein_bot_name

# --- LLM-Auswahl ---
# ask = beim Start fragen, local = immer lokaler llama-server, online = immer Google/Gemma.
LLM_BACKEND=ask

# --- Lokaler LLM-Server (llama-server, OpenAI-kompatibel) ---
LLM_SERVER_URL=http://127.0.0.1:1235/v1/chat/completions
LLM_MODEL=local-model
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_REPEAT_PENALTY=1.15
# repeat_penalty und llama-Extras sind llama.cpp-spezifisch.
# Bei llama-server auf "true" lassen. Für Online-Backend schaltet PandaBot das automatisch aus.
LLM_SEND_REPEAT_PENALTY=true
LLM_SEND_LLAMA_EXTRAS=true
# Anweisungen als "system"-Rolle schicken? Gemma 4 unterstützt über den
# nativen Google-Endpunkt System Instructions; das Online-Profil lässt dies
# standardmäßig aktiv. Für inkompatible Custom-Backends auf false setzen.
LLM_USE_SYSTEM_ROLE=true
LLM_MAX_TOKENS=80
LLM_TIMEOUT=20

# --- Online-LLM: Google Gemini API / Gemma 4 ---
# API-Key aus Google AI Studio: https://aistudio.google.com/app/apikey
# Alternativ wird auch GEMINI_API_KEY oder GOOGLE_LLM_API_KEY erkannt.
GOOGLE_API_KEY=
# Basis-URL für den nativen generateContent-Transport (nicht den OpenAI-Shim).
GOOGLE_LLM_SERVER_URL=https://generativelanguage.googleapis.com/v1beta
# Korrekte API-IDs: gemma-4-31b-it und gemma-4-26b-a4b-it.
# Der häufige Vertipper 'gemini-...' wird automatisch korrigiert.
# Der OpenAI-Kompatibilitäts-Shim liefert für die MoE-Variante aktuell HTTP 500;
# daher nutzt PandaBot nativ generateContent.
GOOGLE_LLM_MODEL=gemma-4-31b-it
# maxOutputTokens >=512 empfohlen (Gemma schreibt oft <thought>-Notizen, die
# PandaBot herausfiltert – das Budget muss die eigentliche Antwort noch hergeben).
GOOGLE_LLM_MAX_TOKENS=512
GOOGLE_LLM_TIMEOUT=45
# Transport für Online-Profil: 'google_native' wird automatisch gesetzt.
# Für lokale Backends: 'openai'.
# LLM_TRANSPORT=google_native

# --- Online-LLM: Z.AI (GLM) ---
# API-Key aus https://z.ai/manage-apikey/apikey-list
# Wird von den GUI-Providern "zai" (normale API) und "zai_coding"
# (Coding-Plan-Abo-Endpoint) als Fallback genutzt, wenn im Profil kein Key steht.
# Alternativ werden auch Z_AI_API_KEY oder ZHIPU_API_KEY erkannt.
ZAI_API_KEY=

# --- Verhalten ---
HISTORY_LENGTH=16       # Wie viele Verlaufs-Turns als Kontext dienen (inkl. eigener Bot-Antworten)
IDLE_THRESHOLD=900      # Sekunden Stille, bevor der Bot von selbst etwas sagt (ereignisgesteuert, kein starrer Zyklus)
IDLE_JITTER=90          # Max. zufällige Sekunden, die zum Threshold addiert werden (natürlicheres Timing)
IDLE_MAX_SOLO_MESSAGES=1  # Max. eigene Idle-Nachrichten ohne neue echte Chat-Nachricht (0 = aus)
CONTEXT_TTL=120         # Sekunden, wie lange Titel/Spiel gecached werden
USER_MEMORY_ENABLED=true
USER_MEMORY_DIR=uservault  # Lokale Markdown-Gedächtnisse pro Twitch-User

# --- Reichhaltige Chatter-Profile (Auto-Summary) ---
# Nach PROFILE_SUMMARY_AFTER echten Interaktionen wird erstmals ein Profil
# (Fakten + Gesprächsstil: wie rede ich mit dieser Person?) erstellt, danach
# alle PROFILE_SUMMARY_INTERVAL Interaktionen aufgefrischt. 0 = aus.
PROFILE_SUMMARY_AFTER=2
PROFILE_SUMMARY_INTERVAL=5
PROFILE_INTERACTIONS_KEPT=8   # Wie viele letzte (User,Bot)-Gespräche pro User im Speicher bleiben
PROFILE_MAX_NOTES=10         # Max. Notiz-Bullets im Profil nach Consolidation
