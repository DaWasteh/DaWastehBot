# ---------------------------------------------------------------------------
# PandaBot Konfiguration
# Kopiere diese Datei zu ".env" und trage deine eigenen Werte ein.
# Die .env wird NICHT versioniert (siehe .gitignore).
# ---------------------------------------------------------------------------

# --- Twitch Application (aus https://dev.twitch.tv/console) ---
TWITCH_CLIENT_ID=hier_deine_client_id
TWITCH_CLIENT_SECRET=hier_dein_client_secret

# Numerische User-IDs (NICHT die Namen!). So findest du sie:
# https://twitchio.dev/en/latest/getting-started/faq.html#bot-id-owner-id
TWITCH_BOT_ID=123456789      # User-ID des Bot-Accounts
TWITCH_OWNER_ID=987654321    # Deine eigene User-ID (der Kanal)

# Anzeigenamen (kosmetisch, für Prompts/Logs)
TWITCH_CHANNEL=dawasteh
TWITCH_BOT_NAME=PandaBot

# --- Lokaler LLM-Server (llama-server, OpenAI-kompatibel) ---
LLM_SERVER_URL=http://127.0.0.1:1235/v1/chat/completions
LLM_MODEL=local-model
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_REPEAT_PENALTY=1.15
LLM_MAX_TOKENS=80
LLM_TIMEOUT=20

# --- Verhalten ---
HISTORY_LENGTH=12       # Wie viele Chat-Zeilen als Kontext mitgegeben werden
IDLE_THRESHOLD=300      # Sekunden Stille, bevor der Bot von selbst etwas sagt
CONTEXT_TTL=120         # Sekunden, wie lange Titel/Spiel gecached werden
