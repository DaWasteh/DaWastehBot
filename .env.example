# ---------------------------------------------------------------------------
# PandaBot Konfiguration
# Kopiere diese Datei zu ".env" und trage deine eigenen Werte ein.
# Die .env wird NICHT versioniert (siehe .gitignore).
# ---------------------------------------------------------------------------

# --- Twitch Application (aus https://dev.twitch.tv/console) ---
TWITCH_CLIENT_ID=hier_deine_client_id
TWITCH_CLIENT_SECRET=hier_dein_client_secret

# Numerische User-IDs (NICHT die Namen!). So findest du sie:
# https://twitchio.dev/en/latest/getting-started/faq.html#bot-id-owner-id
TWITCH_BOT_ID=123456789      # User-ID des Bot-Accounts
TWITCH_OWNER_ID=987654321    # Deine eigene User-ID (der Kanal)

# Anzeigename / zusätzlicher Spitzname, auf den der Bot hört.
# Der echte Account-Name (Login) wird automatisch als Trigger erkannt;
# hier kannst du zusätzlich einen Spitznamen angeben (z. B. "PandaBot").
# Wird außerdem in Prompts/Logs verwendet.
TWITCH_CHANNEL=dawasteh
TWITCH_BOT_NAME=PandaBot

# --- LLM-Auswahl ---
# ask = beim Start fragen, local = immer lokaler llama-server, online = immer Google/Gemma.
LLM_BACKEND=ask

# --- Lokaler LLM-Server (llama-server, OpenAI-kompatibel) ---
LLM_SERVER_URL=http://127.0.0.1:1235/v1/chat/completions
LLM_MODEL=local-model
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_REPEAT_PENALTY=1.15
# repeat_penalty und llama-Extras sind llama.cpp-spezifisch.
# Bei llama-server auf "true" lassen. Für Online-Backend schaltet PandaBot das automatisch aus.
LLM_SEND_REPEAT_PENALTY=true
LLM_SEND_LLAMA_EXTRAS=true
LLM_MAX_TOKENS=80
LLM_TIMEOUT=20

# --- Online-LLM: Google Gemini API / Gemma 4 31B IT ---
# API-Key aus Google AI Studio: https://aistudio.google.com/app/apikey
# Alternativ wird auch GEMINI_API_KEY oder GOOGLE_LLM_API_KEY erkannt.
GOOGLE_API_KEY=
GOOGLE_LLM_SERVER_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GOOGLE_LLM_MODEL=gemma-4-31b-it
GOOGLE_LLM_MAX_TOKENS=120
GOOGLE_LLM_TIMEOUT=30

# --- Verhalten ---
HISTORY_LENGTH=12       # Wie viele Chat-Zeilen als Kontext mitgegeben werden
IDLE_THRESHOLD=300      # Sekunden Stille, bevor der Bot von selbst etwas sagt
CONTEXT_TTL=120         # Sekunden, wie lange Titel/Spiel gecached werden
USER_MEMORY_ENABLED=true
USER_MEMORY_DIR=uservault  # Lokale Markdown-Gedächtnisse pro Twitch-User
